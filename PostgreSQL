Имя суперпользователя postgres
psql - интерактивный терминал PostgreSQL.
psql -U postgres - запуск БД под именем суперпользователя
CREATE USER <Имя пользователя> WITH PASSWORD <Пароль>; - создание пользователя с паролем
CREATE DATABASE <Имя БД> OWNER <Имя пользователя>; - создание БД с указанным хозяином

\d - список всех таблиц базы данных
\d <Имя таблицы> - просмотр таблицы
\du - список всех пользователей
